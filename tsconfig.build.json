{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationDir": "dist/types",
    "stripInternal": true
  },
  "include": [
    "src/index.ts",
    "src/engine/**/*.ts",
    "src/runtime/**/*.ts",
    "src/parts/**/*.ts",
    "src/data/**/*.ts",
    "src/config/**/*.ts",
    "src/materials/**/*.ts"
  ],
  "exclude": [
    "src/captureHarness.ts"
  ]
}
